<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>hamilton_star_bringup</name>
  <version>0.1.0</version>
  <description>Launch files, deck configuration, and systemd unit for the Hamilton STAR action server.</description>

  <maintainer email="guy.burroughes@eit.org">Guy Burroughes</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <exec_depend>hamilton_star_ros</exec_depend>
  <exec_depend>hamilton_star_msgs</exec_depend>
  <exec_depend>ros2launch</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
