<robot name="meca500_arm" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- Base link is the center of the robot's bottom plate -->
  <link name="meca_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_base.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_base.stl" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 1 -->
  <link name="meca_axis_1_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j1.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j1.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0.012498 0 0.091" rpy="0 0 0" />
    <parent link="meca_base_link" />
    <child link="meca_axis_1_link" />
    <axis xyz="0 0 1" />
    <limit effort="10.0" velocity="2.61799" lower="-3.05433" upper="3.05433" />
  </joint>

  <!-- Joint 2 -->
  <link name="meca_axis_2_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j2.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j2.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0 0 0.044" rpy="0 0 0" />
    <parent link="meca_axis_1_link" />
    <child link="meca_axis_2_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="2.61799" lower="-1.22173048" upper="1.5708" />
  </joint>

  <!-- Joint 3 -->
  <link name="meca_axis_3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j3.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j3.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint3" type="revolute">
    <origin xyz="0 0 0.135" rpy="0 0 0" />
    <parent link="meca_axis_2_link" />
    <child link="meca_axis_3_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="3.14159" lower="-2.35619" upper="1.22173048" />
  </joint>

  <!-- Joint 4 -->
  <link name="meca_axis_4_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j4.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j4.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint4" type="revolute">
    <origin xyz="0 0 0.038" rpy="0 0 0" />
    <parent link="meca_axis_3_link" />
    <child link="meca_axis_4_link" />
    <axis xyz="1 0 0" />
    <limit effort="10.0" velocity="5.23599" lower="-2.96706" upper="2.96706" />
  </joint>

  <!-- Joint 5 -->
  <link name="meca_axis_5_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j5.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j5.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint5" type="revolute">
    <origin xyz="0.12 0 0" rpy="0 0 0" />
    <parent link="meca_axis_4_link" />
    <child link="meca_axis_5_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="5.23599" lower="-2.00713" upper="2.00713" />
  </joint>

  <!-- Joint 6 -->
  <link name="meca_axis_6_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j6.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j6.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint6" type="revolute">
    <origin xyz="0.07 0 0" rpy="0 0 0" />
    <parent link="meca_axis_5_link" />
    <child link="meca_axis_6_link" />
    <axis xyz="1 0 0" />
    <limit effort="10.0" velocity="8.72665" lower="-3.14159" upper="3.14159" />
  </joint>

  <!-- ========================================= -->
  <!-- Schunk MEGP 25E gripper (short stroke)    -->
  <!-- ========================================= -->

  <!-- Gripper body (fixed to flange) -->
  <link name="meca_gripper_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_body.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_body.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="meca_gripper_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="meca_axis_6_link" />
    <child link="meca_gripper_link" />
  </joint>

  <!-- Finger 1 (active prismatic joint) -->
  <link name="meca_gripper_finger1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="meca_gripper_finger1_joint" type="prismatic">
    <origin xyz=".01395 .0125 -.0170205" rpy="-1.570796 0 0" />
    <parent link="meca_gripper_link" />
    <child link="meca_gripper_finger1" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.0055" effort="1.0" velocity="0.1" />
  </joint>

  <!-- Finger 2 (mimic of finger 1) -->
  <link name="meca_gripper_finger2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="meca_gripper_finger2_joint" type="prismatic">
    <origin xyz=".01395 -.0125 -.0170205" rpy="-1.570796 0 -3.141593" />
    <parent link="meca_gripper_link" />
    <child link="meca_gripper_finger2" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.0055" effort="1.0" velocity="0.1" />
    <mimic joint="meca_gripper_finger1_joint" multiplier="1.0" offset="0.0" />
  </joint>

  <!-- Tool center point (virtual frame between finger tips) -->
  <link name="gripper_tip_link" />

  <joint name="gripper_tip_joint" type="fixed">
    <origin xyz="0.04 0 -0.017" rpy="-1.5708 0 0" />
    <parent link="meca_gripper_link" />
    <child link="gripper_tip_link" />
  </joint>

</robot>