<robot name="meca500_arm" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- ============================================================ -->
  <!-- Seed-gripper overlay args (local divergence from upstream).   -->
  <!-- When use_seed_gripper=true the Schunk MEGP 25E finger meshes  -->
  <!-- are suppressed and the 3D-printed seed fingers + corrected    -->
  <!-- TCP (seed_gripper_tip_link) are added in their place. The     -->
  <!-- prismatic finger joints + meca_gripper_finger1/2 frames stay  -->
  <!-- so the gripper open/close still drives the seed fingers.      -->
  <!-- Offset values come from providers/meca500/tools/              -->
  <!-- seed_gripper_offsets.yaml (saved by seed_gripper_visualizer). -->
  <!-- ============================================================ -->
  <xacro:arg name="use_seed_gripper" default="false" />
  <xacro:arg name="left_mesh"   default="" />
  <xacro:arg name="right_mesh"  default="" />
  <xacro:arg name="stl_scale"   default="0.001" />
  <xacro:arg name="left_xyz_x"  default="0.0" />
  <xacro:arg name="left_xyz_y"  default="0.0" />
  <xacro:arg name="left_xyz_z"  default="0.0" />
  <xacro:arg name="left_rpy_r"  default="0.0" />
  <xacro:arg name="left_rpy_p"  default="0.0" />
  <xacro:arg name="left_rpy_y"  default="0.0" />
  <xacro:arg name="right_xyz_x" default="0.0" />
  <xacro:arg name="right_xyz_y" default="0.0" />
  <xacro:arg name="right_xyz_z" default="0.0" />
  <xacro:arg name="right_rpy_r" default="0.0" />
  <xacro:arg name="right_rpy_p" default="0.0" />
  <xacro:arg name="right_rpy_y" default="0.0" />
  <xacro:arg name="grip_xyz_x"  default="0.0" />
  <xacro:arg name="grip_xyz_y"  default="0.0" />
  <xacro:arg name="grip_xyz_z"  default="0.0" />
  <xacro:arg name="grip_rpy_r"  default="0.0" />
  <xacro:arg name="grip_rpy_p"  default="0.0" />
  <xacro:arg name="grip_rpy_y"  default="0.0" />

  <!-- Base link is the center of the robot's bottom plate -->
  <link name="meca_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_base.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_base.stl" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 1 -->
  <link name="meca_axis_1_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j1.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j1.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0.012498 0 0.091" rpy="0 0 0" />
    <parent link="meca_base_link" />
    <child link="meca_axis_1_link" />
    <axis xyz="0 0 1" />
    <limit effort="10.0" velocity="2.61799" lower="-3.05433" upper="3.05433" />
  </joint>

  <!-- Joint 2 -->
  <link name="meca_axis_2_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j2.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j2.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0 0 0.044" rpy="0 0 0" />
    <parent link="meca_axis_1_link" />
    <child link="meca_axis_2_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="2.61799" lower="-1.22173048" upper="1.5708" />
  </joint>

  <!-- Joint 3 -->
  <link name="meca_axis_3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j3.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j3.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint3" type="revolute">
    <origin xyz="0 0 0.135" rpy="0 0 0" />
    <parent link="meca_axis_2_link" />
    <child link="meca_axis_3_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="3.14159" lower="-2.35619" upper="1.22173048" />
  </joint>

  <!-- Joint 4 -->
  <link name="meca_axis_4_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j4.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j4.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint4" type="revolute">
    <origin xyz="0 0 0.038" rpy="0 0 0" />
    <parent link="meca_axis_3_link" />
    <child link="meca_axis_4_link" />
    <axis xyz="1 0 0" />
    <limit effort="10.0" velocity="5.23599" lower="-2.96706" upper="2.96706" />
  </joint>

  <!-- Joint 5 -->
  <link name="meca_axis_5_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j5.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j5.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint5" type="revolute">
    <origin xyz="0.12 0 0" rpy="0 0 0" />
    <parent link="meca_axis_4_link" />
    <child link="meca_axis_5_link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="5.23599" lower="-2.00713" upper="2.00713" />
  </joint>

  <!-- Joint 6 -->
  <link name="meca_axis_6_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/meca_500_r3_j6.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/meca_500_r3_j6.stl" />
      </geometry>
    </collision>
  </link>

  <joint name="joint6" type="revolute">
    <origin xyz="0.07 0 0" rpy="0 0 0" />
    <parent link="meca_axis_5_link" />
    <child link="meca_axis_6_link" />
    <axis xyz="1 0 0" />
    <limit effort="10.0" velocity="8.72665" lower="-3.14159" upper="3.14159" />
  </joint>

  <!-- ========================================= -->
  <!-- Schunk MEGP 25E gripper (short stroke)    -->
  <!-- ========================================= -->

  <!-- Gripper body (fixed to flange) -->
  <link name="meca_gripper_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_body.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_body.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="meca_gripper_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="meca_axis_6_link" />
    <child link="meca_gripper_link" />
  </joint>

  <!-- Finger 1 (active prismatic joint). Visual/collision are conditional:
       Schunk MEGP 25E mesh when use_seed_gripper=false, empty when true
       (the seed-gripper block below adds its own meshes parented here). -->
  <link name="meca_gripper_finger1">
    <xacro:unless value="$(arg use_seed_gripper)">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
    </xacro:unless>
  </link>

  <joint name="meca_gripper_finger1_joint" type="prismatic">
    <origin xyz=".01395 .0125 -.0170205" rpy="-1.570796 0 0" />
    <parent link="meca_gripper_link" />
    <child link="meca_gripper_finger1" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.0055" effort="1.0" velocity="0.1" />
  </joint>

  <!-- Finger 2 (mimic of finger 1) -->
  <link name="meca_gripper_finger2">
    <xacro:unless value="$(arg use_seed_gripper)">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://meca500_description/meshes/visual/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://meca500_description/meshes/collision/schunk_megp25e_finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
    </xacro:unless>
  </link>

  <joint name="meca_gripper_finger2_joint" type="prismatic">
    <origin xyz=".01395 -.0125 -.0170205" rpy="-1.570796 0 -3.141593" />
    <parent link="meca_gripper_link" />
    <child link="meca_gripper_finger2" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.0055" effort="1.0" velocity="0.1" />
    <mimic joint="meca_gripper_finger1_joint" multiplier="1.0" offset="0.0" />
  </joint>

  <!-- Tool center point (virtual frame between Schunk finger tips). Stays
       even when use_seed_gripper=true so existing trees / kinematics
       calibrations that target gripper_tip_link don't break; new code
       should target seed_gripper_tip_link below. -->
  <link name="gripper_tip_link" />

  <joint name="gripper_tip_joint" type="fixed">
    <origin xyz="0.04 0 -0.017" rpy="-1.5708 0 0" />
    <parent link="meca_gripper_link" />
    <child link="gripper_tip_link" />
  </joint>

  <!-- Seed-gripper geometry. Only materialised when use_seed_gripper=true.
       Offsets come from launch-time mappings populated from
       providers/meca500/tools/seed_gripper_offsets.yaml. -->
  <xacro:if value="$(arg use_seed_gripper)">
    <link name="seed_finger_left">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(arg left_mesh)"
                scale="$(arg stl_scale) $(arg stl_scale) $(arg stl_scale)" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(arg left_mesh)"
                scale="$(arg stl_scale) $(arg stl_scale) $(arg stl_scale)" />
        </geometry>
      </collision>
    </link>
    <joint name="seed_finger_left_joint" type="fixed">
      <origin xyz="$(arg left_xyz_x) $(arg left_xyz_y) $(arg left_xyz_z)"
              rpy="$(arg left_rpy_r) $(arg left_rpy_p) $(arg left_rpy_y)" />
      <parent link="meca_gripper_finger1" />
      <child link="seed_finger_left" />
    </joint>

    <link name="seed_finger_right">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(arg right_mesh)"
                scale="$(arg stl_scale) $(arg stl_scale) $(arg stl_scale)" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(arg right_mesh)"
                scale="$(arg stl_scale) $(arg stl_scale) $(arg stl_scale)" />
        </geometry>
      </collision>
    </link>
    <joint name="seed_finger_right_joint" type="fixed">
      <origin xyz="$(arg right_xyz_x) $(arg right_xyz_y) $(arg right_xyz_z)"
              rpy="$(arg right_rpy_r) $(arg right_rpy_p) $(arg right_rpy_y)" />
      <parent link="meca_gripper_finger2" />
      <child link="seed_finger_right" />
    </joint>

    <!-- Corrected TCP for the seed gripper: full offset from the gripper
         body mount to the contact point. Use this in place of
         gripper_tip_link for grasp planning. -->
    <link name="seed_gripper_tip_link" />
    <joint name="seed_gripper_tip_joint" type="fixed">
      <origin xyz="$(arg grip_xyz_x) $(arg grip_xyz_y) $(arg grip_xyz_z)"
              rpy="$(arg grip_rpy_r) $(arg grip_rpy_p) $(arg grip_rpy_y)" />
      <parent link="meca_gripper_link" />
      <child link="seed_gripper_tip_link" />
    </joint>
  </xacro:if>

</robot>