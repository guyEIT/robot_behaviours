<?xml version="1.0"?>

<!-- Author: Garrison Johnston 12/2025 -->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- `simulation` must be declared as a xacro:arg (not a macro param) so
         that `$(arg simulation)` inside `<xacro:if>` resolves correctly.
         Xacro evaluates `<xacro:if value="true">` / "false" natively; the
         Python-style `${x == 'true'}` form works inconsistently. The same
         arg is declared in meca500.urdf.xacro and forwarded here. -->
    <xacro:arg name="simulation" default="false"/>

    <xacro:macro name="meca500_ros2_control" params="name initial_positions_file robot_ip robot_port connect_timeout_ms response_timeout_ms auto_home:=false">
        <xacro:property name="initial_positions" value="${load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
        <!-- Hardware plugin selection:
             simulation=false (default) -> real meca500_hardware (TCP to robot)
             simulation=true            -> mock_components/GenericSystem
                                          (stateless loopback, no hardware) -->
        <xacro:if value="$(arg simulation)">
            <hardware>
                <plugin>mock_components/GenericSystem</plugin>
                <param name="mock_sensor_commands">false</param>
                <param name="state_following_offset">0.0</param>
            </hardware>
        </xacro:if>
        <xacro:unless value="$(arg simulation)">
            <hardware>
                <plugin>meca500_hardware/Meca500Hardware</plugin>
                <param name="robot_ip">${robot_ip}</param>
                <param name="robot_port">${robot_port}</param>
                <param name="connect_timeout_ms">${connect_timeout_ms}</param>
                <param name="response_timeout_ms">${response_timeout_ms}</param>
                <!-- Skip the activation-time Home command by default —
                     Meca500 retains absolute encoder homing across power
                     cycles, so once-per-power-on homing is sufficient and
                     blocking the controller-manager activation on Home
                     just slows MoveIt bringup. Pass auto_home:=true on
                     `meca500-real-up` after a fresh power-on. -->
                <param name="auto_home">${auto_home}</param>
            </hardware>
        </xacro:unless>

        <joint name="joint1">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="joint2">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="joint3">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="joint4">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="joint5">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="joint6">
            <command_interface name="position"/>
            <state_interface name="position"/>

        </joint>
        <joint name="meca_gripper_finger1_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>

        </joint>
        </ros2_control>
    </xacro:macro>
</robot>
