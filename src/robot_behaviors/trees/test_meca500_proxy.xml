<!--
  Phase 2 validation tree — same content as test_meca500_sim.xml, but with
  per-action server_name overrides routing to the meca500_skill_server proxy
  under /meca500/skill_atoms/<name> instead of the root-namespaced fleet at
  /skill_atoms/<name>.

  Phase 3 lifts the (robot_id, bt_tag) lookup into the BT executor itself,
  at which point this XML can drop back to the same form as
  test_meca500_sim.xml plus a single `robot_id="meca500"` attribute.

  Validation harness:
    pixi run meca500-proxy-test
    # then submit this tree to /skill_server/execute_behavior_tree
-->
<root BTCPP_format="4" main_tree_to_execute="MecaProxySmokeTest">

  <BehaviorTree ID="MecaProxySmokeTest">
    <Sequence name="meca_proxy_main">
      <LogEvent name="log_start"
                event_name="meca_proxy_test_start"
                severity="info"
                message="Meca500 proxy smoke test starting"/>

      <CheckSystemReady name="check_meca_ready"
                        server_name="/meca500/skill_atoms/check_system_ready"
                        timeout_sec="10.0"/>

      <MoveToNamedConfig name="go_home_start"
                         server_name="/meca500/skill_atoms/move_to_named_config"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <MoveToJointConfig name="go_to_pre_pick"
                         server_name="/meca500/skill_atoms/move_to_joint_config"
                         joint_positions="0.9902, 0.2692, 1.0904, -0.2384, -1.2858, 0.2633"
                         velocity_scaling="0.3"/>

      <WaitForDuration name="settle" seconds="0.5"/>

      <MoveToJointConfig name="go_to_over_seed"
                         server_name="/meca500/skill_atoms/move_to_joint_config"
                         joint_positions="1.3954, 0.5605, 0.4706, 0.0727, 0.5396, -0.3589"
                         velocity_scaling="0.25"/>

      <WaitForDuration name="settle_again" seconds="0.5"/>

      <MoveToNamedConfig name="go_home_end"
                         server_name="/meca500/skill_atoms/move_to_named_config"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <LogEvent name="log_done"
                event_name="meca_proxy_test_done"
                severity="info"
                message="Meca500 proxy smoke test complete"/>
    </Sequence>
  </BehaviorTree>

</root>
