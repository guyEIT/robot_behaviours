<!--
  Meca500 sim smoke test — validated SUCCESS E2E 2026-04-25 (~9s).

  Run via the lab-sim:
    pixi run lab-sim-up
    # then in dashboard preset selector: test_meca500_sim → Run

  The tree runs CheckSystemReady then plans four motions through MoveIt
  against fake_hardware (mock_components/GenericSystem):
    home → seed-ready joint config → over-seed joint config → home

  No `server_name=` overrides — lab-sim launches atoms at the root
  namespace (`/skill_atoms/<name>`), matching tree_executor's default
  ACTION_REGISTRY paths. The same XML works against the production
  meca500-host setup if its atoms are also launched at the root, OR if
  the BT is wrapped/forked with explicit `server_name="/meca500/..."`
  overrides per action node.
-->
<root BTCPP_format="4" main_tree_to_execute="MecaSimSmokeTest">

  <BehaviorTree ID="MecaSimSmokeTest">
    <Sequence name="meca_sim_main">
      <LogEvent name="log_start"
                event_name="meca_sim_test_start"
                severity="info"
                message="Meca500 sim smoke test starting"/>

      <CheckSystemReady name="check_meca_ready"
                        timeout_sec="10.0"/>

      <!-- Go to home, then two joint configs within Meca workspace, then home -->
      <MoveToNamedConfig name="go_home_start"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <MoveToJointConfig name="go_to_pre_pick"
                         joint_positions="0.9902, 0.2692, 1.0904, -0.2384, -1.2858, 0.2633"
                         velocity_scaling="0.3"/>

      <WaitForDuration name="settle" seconds="0.5"/>

      <MoveToJointConfig name="go_to_over_seed"
                         joint_positions="1.3954, 0.5605, 0.4706, 0.0727, 0.5396, -0.3589"
                         velocity_scaling="0.25"/>

      <WaitForDuration name="settle_again" seconds="0.5"/>

      <MoveToNamedConfig name="go_home_end"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <LogEvent name="log_done"
                event_name="meca_sim_test_done"
                severity="info"
                message="Meca500 sim smoke test complete"/>
    </Sequence>
  </BehaviorTree>

</root>
