<!--
  Meca500 sim smoke test — validated SUCCESS E2E 2026-04-24 (9.85s).

  Preconditions (on the Meca500-host PC, three shells):
    pixi run meca500-sim-up      # MoveIt2 with mock_components/GenericSystem
    pixi run meca500-up          # skill atoms under /meca500
    pixi run orchestrator-up     # (on control PC, or same box for smoke tests)

  Then either submit via the dashboard or directly:
    ros2 action send_goal /skill_server/execute_behavior_tree \
      robot_skills_msgs/action/ExecuteBehaviorTree \
      "{tree_xml: '<contents of this file>', tree_name: test_meca500_sim}"

  The tree runs CheckSystemReady then plans four motions through MoveIt
  against fake_hardware:
    home → seed-ready joint config → over-seed joint config → home

  server_name overrides route each action to /meca500/skill_atoms/<name>
  because tree_executor's default ACTION_REGISTRY uses /skill_atoms/ (no
  namespace). Remote atoms self-register under the robot's namespace.
-->
<root BTCPP_format="4" main_tree_to_execute="MecaSimSmokeTest">

  <BehaviorTree ID="MecaSimSmokeTest">
    <Sequence name="meca_sim_main">
      <LogEvent name="log_start"
                event_name="meca_sim_test_start"
                severity="info"
                message="Meca500 sim smoke test starting"/>

      <CheckSystemReady name="check_meca_ready"
                        server_name="/meca500/skill_atoms/check_system_ready"
                        timeout_sec="10.0"/>

      <!-- Go to home, then two joint configs within Meca workspace, then home -->
      <MoveToNamedConfig name="go_home_start"
                         server_name="/meca500/skill_atoms/move_to_named_config"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <MoveToJointConfig name="go_to_pre_pick"
                         server_name="/meca500/skill_atoms/move_to_joint_config"
                         joint_positions="0.9902, 0.2692, 1.0904, -0.2384, -1.2858, 0.2633"
                         velocity_scaling="0.3"/>

      <WaitForDuration name="settle" seconds="0.5"/>

      <MoveToJointConfig name="go_to_over_seed"
                         server_name="/meca500/skill_atoms/move_to_joint_config"
                         joint_positions="1.3954, 0.5605, 0.4706, 0.0727, 0.5396, -0.3589"
                         velocity_scaling="0.25"/>

      <WaitForDuration name="settle_again" seconds="0.5"/>

      <MoveToNamedConfig name="go_home_end"
                         server_name="/meca500/skill_atoms/move_to_named_config"
                         config_name="home"
                         velocity_scaling="0.3"/>

      <LogEvent name="log_done"
                event_name="meca_sim_test_done"
                severity="info"
                message="Meca500 sim smoke test complete"/>
    </Sequence>
  </BehaviorTree>

</root>
