# ROS2 build artifacts
build/
install/
log/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/

# CMake
CMakeCache.txt
CMakeFiles/
*.cmake
!*Config.cmake
!*ConfigVersion.cmake

# Compiled objects
*.o
*.so
*.dylib
*.a

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.code-workspace
.DS_Store

# Build artifacts
compile_commands.json

# Compound skills persisted by agents (optional - may want to commit these)
# ~/.ros2_robot_skills/

# colcon metadata cache
.colcon/

# pytest
.pytest_cache/
.coverage
htmlcov/

# Environment
.env

# Pixi
.pixi/

# Provider workspace build artifacts (each subtree is its own colcon/pixi workspace)
providers/*/build/
providers/*/install/
providers/*/log/
providers/*/.pixi/
providers/*/ros2_ws/build/
providers/*/ros2_ws/install/
providers/*/ros2_ws/log/
# pixi-build-ros files.txt is emitted next to each package manifest with
# absolute paths from the build cache. Upstream pbi_liconic currently
# tracks these; we don't want them regenerated-and-committed on every build.
providers/pbi_liconic/ros2_ws/src/*/files.txt

# Host-local binaries (Groot2 etc.)
.local/
